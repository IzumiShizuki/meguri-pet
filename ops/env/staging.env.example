COMPOSE_PROJECT_NAME=meguri-staging
MEGURI_ENV=staging
MEGURI_RELEASE_ID=meguri-staging-replace-me
MEGURI_DATA_BUILD_ID=meguri_v2_02c3db0c507d7c2d

MEGURI_CORE_IMAGE=ghcr.io/izumishizuki/meguri-core:staging-candidate
MEGURI_MIGRATION_IMAGE=ghcr.io/izumishizuki/meguri-migration:staging-candidate
MEGURI_POSTGRES_IMAGE=pgvector/pgvector:0.8.5-pg16-bookworm
MEGURI_CORE_PORT=18080
MEGURI_IMAGE_PULL_POLICY=always
MEGURI_HEALTH_PROBE_MODE=http

MEGURI_EDGE_NETWORK=meguri-staging-edge
MEGURI_INTERNAL_NETWORK=meguri-staging-internal
MEGURI_POSTGRES_VOLUME=meguri-staging-postgres-data
MEGURI_POSTGRES_DB=meguri_staging
MEGURI_POSTGRES_USER=meguri_staging_migration
MEGURI_POSTGRES_APP_USER=meguri_staging_app
MEGURI_TENANT_ID=meguri-staging

MEGURI_DATA_DIR=/opt/meguri/staging/config/data
MEGURI_RELEASE_MANIFEST_FILE=/opt/meguri/staging/config/release-manifest.json
MEGURI_CORE_LOG_DIR=/opt/meguri/staging/logs/core
MEGURI_POSTGRES_LOG_DIR=/opt/meguri/staging/logs/postgres
MEGURI_BACKUP_DIR=/opt/meguri/staging/backups
MEGURI_CONTROL_PLANE_MANIFEST_FILE=
MEGURI_CONTROL_PLANE_BACKUP_DIR=

MEGURI_POSTGRES_PASSWORD_FILE=/opt/meguri/staging/secrets/postgres-password.txt
MEGURI_DATABASE_URL_FILE=/opt/meguri/staging/secrets/database-url.txt
MEGURI_MIGRATION_DATABASE_URL_FILE=/opt/meguri/staging/secrets/migration-database-url.txt
MEGURI_POSTGRES_APP_PASSWORD_FILE=/opt/meguri/staging/secrets/postgres-app-password.txt
MEGURI_LLM_API_KEY_FILE=/opt/meguri/staging/secrets/llm-api-key.txt
MEGURI_JWT_SECRET_FILE=/opt/meguri/staging/secrets/jwt-secret.txt
MEGURI_ASTRBOT_SHARED_TOKEN_FILE=/opt/meguri/staging/secrets/astrbot-shared-token.txt

MEGURI_MEMORY_PROVIDER=native_pgvector
MEGURI_LLM_PROVIDER=openai-compatible
MEGURI_LLM_BASE_URL=https://replace-with-authenticated-llm-gateway.example/v1
MEGURI_LLM_MODEL=meguri-text-staging-candidate
MEGURI_LLM_TIMEOUT_SECONDS=60
MEGURI_LLM_MAX_CONCURRENCY=4
MEGURI_LLM_RESPONSE_FORMAT=json_schema
MEGURI_LLM_RELEASE_CHANNEL=candidate
MEGURI_PUBLIC_BASE_URL=https://replace-with-staging-entry.example
MEGURI_ALLOWED_ORIGINS=https://replace-with-staging-client.example
MEGURI_ENABLE_DEBUG_ROUTES=false
MEGURI_MUTATION_ALLOWED=false
MEGURI_LOG_LEVEL=INFO

MEGURI_DATABASE_REVISION=20260714_0004
MEGURI_EMBEDDING_MODEL_REVISION=5617a9f61b028005a4858fdac845db406aefb181
MEGURI_LLM_BASE_MODEL_REVISION=replace-with-pinned-base-revision
MEGURI_LLM_ADAPTER_REVISION=replace-with-adapter-revision
MEGURI_LLM_ADAPTER_SHA256=replace-with-adapter-sha256
MEGURI_MODEL_REGISTRY_ID=replace-with-model-registry-id
