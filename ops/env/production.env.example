COMPOSE_PROJECT_NAME=meguri-production
MEGURI_ENV=production
MEGURI_RELEASE_ID=meguri-production-replace-me
MEGURI_DATA_BUILD_ID=meguri_v2_02c3db0c507d7c2d

MEGURI_CORE_IMAGE=ghcr.io/izumishizuki/meguri-core:production-last-good
MEGURI_MIGRATION_IMAGE=ghcr.io/izumishizuki/meguri-migration:production-last-good
MEGURI_POSTGRES_IMAGE=pgvector/pgvector:0.8.5-pg16-bookworm

MEGURI_EDGE_NETWORK=meguri-production-edge
MEGURI_INTERNAL_NETWORK=meguri-production-internal
MEGURI_POSTGRES_VOLUME=meguri-production-postgres-data
MEGURI_POSTGRES_DB=meguri_production
MEGURI_POSTGRES_USER=meguri_production_migration
MEGURI_POSTGRES_APP_USER=meguri_production_app
MEGURI_TENANT_ID=meguri-production

MEGURI_DATA_DIR=/opt/meguri/production/config/data
MEGURI_RELEASE_MANIFEST_FILE=/opt/meguri/production/config/release-manifest.json
MEGURI_CORE_LOG_DIR=/opt/meguri/production/logs/core
MEGURI_POSTGRES_LOG_DIR=/opt/meguri/production/logs/postgres
MEGURI_BACKUP_DIR=/opt/meguri/production/backups

MEGURI_POSTGRES_PASSWORD_FILE=/opt/meguri/production/secrets/postgres-password.txt
MEGURI_DATABASE_URL_FILE=/opt/meguri/production/secrets/database-url.txt
MEGURI_MIGRATION_DATABASE_URL_FILE=/opt/meguri/production/secrets/migration-database-url.txt
MEGURI_POSTGRES_APP_PASSWORD_FILE=/opt/meguri/production/secrets/postgres-app-password.txt
MEGURI_LLM_API_KEY_FILE=/opt/meguri/production/secrets/llm-api-key.txt
MEGURI_JWT_SECRET_FILE=/opt/meguri/production/secrets/jwt-secret.txt
MEGURI_ASTRBOT_SHARED_TOKEN_FILE=/opt/meguri/production/secrets/astrbot-shared-token.txt

MEGURI_MEMORY_PROVIDER=native_pgvector
MEGURI_LLM_PROVIDER=openai-compatible
MEGURI_LLM_BASE_URL=https://replace-with-production-llm-gateway.example/v1
MEGURI_LLM_MODEL=meguri-text-production-last-good
MEGURI_LLM_TIMEOUT_SECONDS=60
MEGURI_LLM_MAX_CONCURRENCY=8
MEGURI_LLM_RELEASE_CHANNEL=last-good
MEGURI_PUBLIC_BASE_URL=https://replace-with-production-entry.example
MEGURI_ALLOWED_ORIGINS=https://replace-with-production-client.example
MEGURI_ENABLE_DEBUG_ROUTES=false
MEGURI_MUTATION_ALLOWED=false
MEGURI_LOG_LEVEL=INFO

MEGURI_DATABASE_REVISION=20260714_0004
MEGURI_EMBEDDING_MODEL_REVISION=5617a9f61b028005a4858fdac845db406aefb181
MEGURI_LLM_BASE_MODEL_REVISION=replace-with-pinned-base-revision
MEGURI_LLM_ADAPTER_REVISION=replace-with-adapter-revision
MEGURI_LLM_ADAPTER_SHA256=replace-with-adapter-sha256
MEGURI_MODEL_REGISTRY_ID=replace-with-model-registry-id
MEGURI_LLM_GENERATION_PROFILE_ID=replace-with-generation-profile-id
MEGURI_LLM_GENERATION_PROFILE_SHA256=replace-with-generation-profile-sha256
