COMPOSE_PROJECT_NAME=meguri-dev
MEGURI_ENV=dev
MEGURI_RELEASE_ID=meguri-dev-local
MEGURI_DATA_BUILD_ID=meguri_v2_02c3db0c507d7c2d

MEGURI_CORE_IMAGE=meguri-core:dev-ad8d405
MEGURI_MIGRATION_IMAGE=meguri-migration:dev-ad8d405
MEGURI_POSTGRES_IMAGE=pgvector/pgvector:0.8.5-pg16-bookworm
MEGURI_CORE_PORT=18000

MEGURI_EDGE_NETWORK=meguri-dev-edge
MEGURI_INTERNAL_NETWORK=meguri-dev-internal
MEGURI_POSTGRES_VOLUME=meguri-dev-postgres-data
MEGURI_POSTGRES_DB=meguri_dev
MEGURI_POSTGRES_USER=meguri_dev_migration
MEGURI_POSTGRES_APP_USER=meguri_dev_app

MEGURI_DATA_DIR=/opt/meguri/dev/config/data
MEGURI_RELEASE_MANIFEST_FILE=/opt/meguri/dev/config/release-manifest.json
MEGURI_CORE_LOG_DIR=/opt/meguri/dev/logs/core
MEGURI_POSTGRES_LOG_DIR=/opt/meguri/dev/logs/postgres
MEGURI_BACKUP_DIR=/opt/meguri/dev/backups

MEGURI_POSTGRES_PASSWORD_FILE=/opt/meguri/dev/secrets/postgres-password.txt
MEGURI_DATABASE_URL_FILE=/opt/meguri/dev/secrets/database-url.txt
MEGURI_MIGRATION_DATABASE_URL_FILE=/opt/meguri/dev/secrets/migration-database-url.txt
MEGURI_POSTGRES_APP_PASSWORD_FILE=/opt/meguri/dev/secrets/postgres-app-password.txt
MEGURI_LLM_API_KEY_FILE=/opt/meguri/dev/secrets/llm-api-key.txt
MEGURI_JWT_SECRET_FILE=/opt/meguri/dev/secrets/jwt-secret.txt
MEGURI_ASTRBOT_SHARED_TOKEN_FILE=/opt/meguri/dev/secrets/astrbot-shared-token.txt

MEGURI_MEMORY_PROVIDER=fake
MEGURI_LLM_PROVIDER=mock
MEGURI_LLM_BASE_URL=
MEGURI_LLM_MODEL=mock-v1
MEGURI_LLM_TIMEOUT_SECONDS=30
MEGURI_LLM_MAX_CONCURRENCY=4
MEGURI_LLM_RELEASE_CHANNEL=mock
MEGURI_PUBLIC_BASE_URL=http://127.0.0.1:18000
MEGURI_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MEGURI_ENABLE_DEBUG_ROUTES=true
MEGURI_MUTATION_ALLOWED=true
MEGURI_LOG_LEVEL=DEBUG

MEGURI_DATABASE_REVISION=20260714_0001
MEGURI_EMBEDDING_MODEL_REVISION=not-configured
MEGURI_LLM_BASE_MODEL_REVISION=mock-v1
MEGURI_LLM_ADAPTER_REVISION=none
MEGURI_LLM_ADAPTER_SHA256=none
