{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["reply", "expression_tag", "expression_intensity", "voice_style", "memory_candidates"],
  "properties": {
    "reply": {"type": "string", "minLength": 1},
    "expression_tag": {
      "type": "string",
      "enum": ["affectionate", "angry", "confused", "embarrassed", "excited", "happy", "neutral", "sad", "sleepy", "surprised", "teasing", "worried"]
    },
    "expression_intensity": {"type": "string", "enum": ["low", "medium", "high"]},
    "voice_style": {
      "type": "string",
      "enum": ["neutral", "soft", "cheerful", "restrained", "sleepy", "teasing", "affectionate", "worried"]
    },
    "memory_candidates": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "summary", "confidence", "sensitivity", "source_scope"],
        "properties": {
          "type": {"enum": ["preference", "identity", "project", "commitment", "relationship", "routine", "event"]},
          "summary": {"type": "string", "minLength": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "sensitivity": {"enum": ["normal", "private", "sensitive"]},
          "source_scope": {"enum": ["current_message", "conversation"]}
        }
      }
    }
  }
}
